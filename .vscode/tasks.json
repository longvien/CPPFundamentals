{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "C++: GCC build active file",
            "command": "/opt/homebrew/bin/g++-15",
            "args": [
                "-std=c++17",
                "-O2",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}